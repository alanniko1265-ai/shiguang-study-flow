{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "拾光",
  "version": "0.4.2",
  "identifier": "com.studyflow.shiguang",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "拾光 · 学习记录",
        "width": 1280,
        "height": 820,
        "minWidth": 360,
        "minHeight": 640,
        "resizable": true,
        "decorations": false,
        "shadow": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "记录投入，看见成长",
    "longDescription": "本地优先的学习记录、统计与激励工具"
  }
}
